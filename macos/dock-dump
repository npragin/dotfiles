#!/usr/bin/env bash
set -euo pipefail

DOCK_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/macos/dock.txt"

defaults read com.apple.dock persistent-apps | /usr/bin/python3 -c "
import sys, re, urllib.parse
for m in re.finditer(r'_CFURLString\" = \"file://([^\"]+)\"', sys.stdin.read()):
    print(urllib.parse.unquote(m.group(1)).rstrip('/'))
" > "$DOCK_FILE"
